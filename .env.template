# Hermes Groundsman — Client Environment Configuration
# Copy this file to .env and fill in values

# REQUIRED: Anthropic API key for this client
ANTHROPIC_API_KEY=

# REQUIRED: Slack bot credentials (per-client Slack app)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_NAME=new-leads

# Client identity
COMPANY_NAME=

# Service area (zip code range)
SERVICE_AREA_ZIPS=

# Twilio SMS (optional — leave blank if iMessage-only)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Asana integration (optional)
ASANA_PAT=

# Google OAuth (optional)
GOOGLE_CREDENTIALS_PATH=config/google-oauth-credentials.json
GOOGLE_TOKEN_PATH=config/google-oauth-token.json

# Zapier webhook (optional)
ZAPIER_WEBHOOK_URL=

# Do not change
GROUNDSMAN_MODE=true
